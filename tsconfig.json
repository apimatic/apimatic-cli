{
  "compilerOptions": {
    "declaration": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "module": "nodenext",
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "target": "es2017",
    "lib": ["es2018", "dom"],
    "inlineSourceMap": false,
    "moduleResolution": "nodenext",
    "allowSyntheticDefaultImports": true,
  },
  "include": [
    "src/**/*"
  ], 
  "ts-node": {
    "esm": true
  }
}
