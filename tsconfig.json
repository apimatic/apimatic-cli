{
  "compilerOptions": {
    "declaration": true,
    "importHelpers": true,
    "composite": true,
    "skipLibCheck": true,
    "module": "commonjs",
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "target": "es2017",
    "lib": ["es2018", "dom"],
    "baseUrl": ".",
    "paths": {
      "@apimatic/sdk": ["./src/sdk"]
    },
    "inlineSourceMap": true
  },
  "include": [
    "src/**/*"
  ]
}
